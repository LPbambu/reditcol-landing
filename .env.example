# ================================
# CREDITCOL — Variables de entorno
# ================================
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas el archivo .env a GitHub.

# ----- Supabase -----
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ----- App -----
APP_ENV=production
APP_URL=https://tu-dominio.com

# ----- WhatsApp -----
# Número internacional SIN + ni espacios. Ejemplo Colombia: 573001234567
WHATSAPP_NUMBER=573001234567

# ----- Meta Pixel -----
# ID del pixel de Meta (Facebook Ads)
META_PIXEL_ID=tu-pixel-id-aqui
